# Absolute path to wabridge data directory.
# This path is bind-mounted identically into the container so that
# media paths returned by download_media work on both host and container.
WABRIDGE_DATA_DIR=/home/youruser/.wabridge

# UID/GID of the host user — container runs as this user so files
# created inside are owned by you on the host.
# Run: id -u / id -g to find your values.
WABRIDGE_UID=1000
WABRIDGE_GID=1000

# Access level controls which action tools are enabled.
# 0 = read-only (query tools only)
# 1 = read + media download
# 2 = read + download + history sync
# 3 = full access (default)
WABRIDGE_ACCESS_LEVEL=3

# Per-feature overrides applied on top of the access level.
# Comma-separated, prefix with + to enable or - to disable.
# Valid features: send, download, history-sync
# Example: +download,-send
WABRIDGE_FEATURES=
